# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# Visual Studio / Rider
.vs/
*.csproj
*.sln
*.suo
*.user
*.userprefs
*.unityproj

# OS generated
.DS_Store
Thumbs.db

# Unity asset meta files should be included (don't ignore .meta files)

# Crash logs
crashlytics-build.properties

# Mono/Unity crash dumps
mono_crash.*.blob

# Local simulator recordings (each machine keeps its own; not shared via git)
Matlab/sim_out.mat

# Android/Quest build output. Unity drops these beside the project, so the [Bb]uild/
# rules above don't catch them. The BackUpThisFolder one is ~645 MB and the APK ~66 MB
# — both way over GitHub's 100 MB per-file limit.
*.apk
*.aab
*_BurstDebugInformation_DoNotShip/
*_BackUpThisFolder_ButDontShipItWithYourGame/
.utmp/

# Injected into Assets/ during a build and normally cleaned up afterwards:
# Live Capture writes SettingsAssetBuild/, the test framework writes the run info.
Assets/SettingsAssetBuild/
Assets/SettingsAssetBuild.meta
# Assets/Resources/ currently holds ONLY test-framework run info (nothing calls
# Resources.Load anywhere in Assets/). If real runtime resources are ever added,
# delete these two lines and commit the folder.
Assets/Resources/
Assets/Resources.meta
